// ============================================
// 404 NOT FOUND HANDLER - Xử lý khi không tìm thấy endpoint
// ============================================

app.use(notFoundHandler)

// ============================================
// ERROR HANDLING MIDDLEWARE - Xử lý lỗi toàn cầu (phải ở cuối)
// ============================================

app.use(errorHandler)

// ============================================
// SERVER STARTUP - Khởi động máy chủ
// ============================================

const startServer = async () => {
  try {
    // Kiểm tra kết nối cơ sở dữ liệu
    // await prisma.$connect()
    console.log('✅ Mock API ready - No database needed')

    // Khởi động máy chủ
    app.listen(PORT, () => {
      console.log(`
╔════════════════════════════════════════╗
║  🍽️  Restora Backend - Nhà hàng       ║
╚════════════════════════════════════════╝

🚀 Máy chủ đang chạy: http://localhost:${PORT}
📊 Môi trường: ${process.env.NODE_ENV || 'development'}
🔄 CORS Origin: ${CORS_ORIGIN}

Nhấn Ctrl+C để dừng máy chủ...
      `)
    })
  } catch (error) {
    console.error('❌ Không thể khởi động máy chủ:', error)
    process.exit(1)
  }
}

// Xử lý graceful shutdown - Dừng máy chủ một cách đẹp
process.on('SIGINT', async () => {
  console.log('\n🛑 Dừng máy chủ...')
  // await prisma.$disconnect()
  process.exit(0)
})

// Khởi động ứng dụng
startServer()

export default app
