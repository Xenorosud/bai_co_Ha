/**
 * File Main - Ứng dụng Express chính
 * Tệp này khởi tạo máy chủ Express với tất cả các routes và middleware
 */

import express, { Application, Request, Response, NextFunction } from 'express'
import cors from 'cors'
import dotenv from 'dotenv'
// import { PrismaClient } from '@prisma/client'

// Import routes - TEMPORARILY COMMENTED OUT FOR MOCK APIs
// import authRoutes from './routes/auth.routes'
// import dishesRoutes from './routes/dishes.routes'
// import tablesRoutes from './routes/tables.routes'
// import ordersRoutes from './routes/orders.routes'
// import reservationsRoutes from './routes/reservations.routes'
// import inventoryRoutes from './routes/inventory.routes'
// import transactionsRoutes from './routes/transactions.routes'
// import employeesRoutes from './routes/employees.routes'

// Import middleware
import { errorHandler, notFoundHandler } from './middleware/errorHandler'

// Tải biến môi trường từ file .env
dotenv.config()

// Khởi tạo Prisma Client
// const prisma = new PrismaClient()

// Khởi tạo ứng dụng Express
const app: Application = express()
const PORT = process.env.PORT || 3001
const CORS_ORIGIN = process.env.CORS_ORIGIN || 'http://localhost:5173'

// ============================================
// MIDDLEWARE - CẤU HÌNH MIDDLEWARE TOÀN CỤC
// ============================================

// CORS Configuration - Cấu hình CORS
app.use(cors({
  origin: CORS_ORIGIN,
  credentials: true
}))

// Body Parser - Phân tích body request
app.use(express.json({ limit: '10mb' }))
app.use(express.urlencoded({ limit: '10mb', extended: true }))

// ============================================
// ROUTES CƠ BẢN & KIỂM TRA TRẠNG THÁI
// ============================================

// Health Check Route - Kiểm tra trạng thái máy chủ
app.get('/api/health', (req: Request, res: Response) => {
  res.json({
    status: 'OK',
    message: 'Restora Backend đang chạy bình thường',
    timestamp: new Date().toISOString(),
    version: '1.0.0',
  })
})

// Simple test route
app.get('/api/test', (req: Request, res: Response) => {
  res.json({
    status: 'OK',
    message: 'Test route works!',
    timestamp: new Date().toISOString(),
  })
})

