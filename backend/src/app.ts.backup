      typeId: 2,
      availability: true,
      createdAt: new Date(),
      updatedAt: new Date(),
      dishType: { id: 2, name: 'Món chính' }
    },
    {
      id: 2,
      name: 'Gỏi cuốn tôm thịt',
      description: 'Gỏi cuốn tươi ngon với tôm và thịt',
      price: 45000,
      image: 'https://images.unsplash.com/photo-1569718212165-3a8278d5f624?w=500',
